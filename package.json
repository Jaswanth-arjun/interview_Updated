{
  "name": "interview-practice-assistant",
  "version": "1.0.0",
  "description": "On-screen interview practice assistant for mock interviews",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "koffi": "^3.1.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.interview.copilot",
    "productName": "Interview Copilot",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!landing/**/*",
      "!server/**/*"
    ]
  }
}
